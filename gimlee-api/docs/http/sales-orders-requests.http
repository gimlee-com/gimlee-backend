### Fetch My Orders (with filters)
# Requires USER role authentication
# Fetches orders for the authenticated seller.
# Supports filtering by status, date range, ad ID, and buyer username search.
# @name /sales/orders/ [GET]
GET {{host}}/api/sales/orders/?p=0
Authorization: Bearer {{auth_token}}

### Fetch My Orders - Filter by Status
GET {{host}}/api/sales/orders/?p=0&status=AWAITING_PAYMENT&status=COMPLETE
Authorization: Bearer {{auth_token}}

### Fetch My Orders - Search by Buyer Username
GET {{host}}/api/sales/orders/?p=0&q=john
Authorization: Bearer {{auth_token}}

### Fetch My Orders - Filter by Ad ID
GET {{host}}/api/sales/orders/?p=0&adId=60f8f9b3a9d9e8f8a8b8c8d8
Authorization: Bearer {{auth_token}}

### Fetch My Orders - Filter by Date Range, Sort by Amount
GET {{host}}/api/sales/orders/?p=0&from=2024-01-01T00:00:00Z&to=2024-12-31T23:59:59Z&by=AMOUNT&dir=DESC
Authorization: Bearer {{auth_token}}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "content": [
#     {
#       "id": "60f8f9b3a9d9e8f8a8b8c8d8",
#       "status": "AWAITING_PAYMENT",
#       "paymentStatus": "PENDING",
#       "createdAt": "2023-01-01T10:00:00Z",
#       "totalAmount": 100.0,
#       "currency": "ARRR",
#       "items": [
#         {
#           "adId": "60f8f9b3a9d9e8f8a8b8c8d7",
#           "title": "Ad Title",
#           "quantity": 1,
#           "unitPrice": 100.0
#         }
#       ],
#       "buyer": {
#         "username": "buyer_username",
#         "avatarUrl": "/media/avatars/5f8f.jpg"
#       },
#       "primaryThumbnailPath": "/media/ads/main-photo.jpg",
#       "itemCount": 1
#     }
#   ],
#   "totalPages": 1,
#   "totalElements": 1,
#   ...
# }

###

### Fetch Single Order Detail
# Requires USER role authentication (seller only)
# Returns full details for a specific sales order.
# @name /sales/orders/{purchaseId} [GET]
GET {{host}}/api/sales/orders/60f8f9b3a9d9e8f8a8b8c8d8
Authorization: Bearer {{auth_token}}

