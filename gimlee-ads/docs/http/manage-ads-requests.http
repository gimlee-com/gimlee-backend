### Create a New Ad
# Requires USER role authentication
# Creates an ad in an INACTIVE state.
# @name /sales/ads [POST]
POST {{host}}/api/sales/ads
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "title": "My Awesome New Ad Title"
}

### Expected Response (Success - 201 Created):
# Content-Type: application/json
#
# {
#   "id": "60f8f9b3a9d9e8f8a8b8c8d8", // Example generated Ad ID
#   "title": "My Awesome New Ad Title",
#   "description": null,
#   "price": null,
#   "currency": null,
#   "status": "INACTIVE",
#   "userId": "5f8f8f8f8f8f8f8f8f8f8f8f", // Example User ID
#   "location": null,
#   "mediaPaths": [],
#   "mainPhotoPath": null,
#   "stock": 0,
#   "lockedStock": 0,
#   "availableStock": 0,
#   "createdAt": "2023-01-01T10:00:00Z",
#   "updatedAt": "2023-01-01T10:00:00Z"
# }


### Update an Existing Ad
# Requires USER role authentication
# Can update both INACTIVE and ACTIVE ads.
# If the ad is ACTIVE, the resulting state must remain complete (title, description, price,
# settlement currencies, location, stock > 0). Otherwise, the request is rejected with
# AD_ACTIVE_AD_INCOMPLETE_UPDATE suggesting to deactivate the ad first.
# Uses optimistic locking — concurrent modifications return 409 AD_CONCURRENT_MODIFICATION.
# Replace {adId} with the actual ID of the ad you want to update.
#
# Pricing Modes:
#   FIXED_CRYPTO — set fixedPrices (price per settlement currency). No conversion at purchase time.
#   PEGGED — set price, priceCurrency, and settlementCurrencies. Live conversion at purchase time.
#
# @name /sales/ads/{adId} [PUT] - FIXED_CRYPTO example
PUT {{host}}/api/sales/ads/{adId}
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "title": "Updated Ad Title",
  "description": "This is a detailed description of the item.",
  "pricingMode": "FIXED_CRYPTO",
  "fixedPrices": {
    "ARRR": 100.00,
    "YEC": 5000.00
  },
  "categoryId": 5181,
  "location": {
    "cityId": "city-id-123",
    "point": [19.9450, 50.0647]
  },
  "mediaPaths": [
    "path/to/media/image1.jpg",
    "path/to/media/details/image2.png"
  ],
  "mainPhotoPath": "path/to/media/image1.jpg",
  "stock": 10,
  "volatilityProtection": true
}

### Update an Existing Ad — PEGGED example
# @name /sales/ads/{adId} [PUT] - PEGGED example
PUT {{host}}/api/sales/ads/{adId}
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "title": "Updated Ad Title",
  "description": "This is a detailed description of the item.",
  "pricingMode": "PEGGED",
  "price": 19.99,
  "priceCurrency": "USD",
  "settlementCurrencies": ["ARRR", "YEC"],
  "categoryId": 5181,
  "location": {
    "cityId": "city-id-123",
    "point": [19.9450, 50.0647]
  },
  "mediaPaths": [
    "path/to/media/image1.jpg",
    "path/to/media/details/image2.png"
  ],
  "mainPhotoPath": "path/to/media/image1.jpg",
  "stock": 10,
  "volatilityProtection": true
}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "id": "{adId}", // The updated Ad ID
#   "title": "Updated Ad Title",
#   "description": "This is a detailed description of the item.",
#   "price": 19.99,
#   "currency": "YEC",
#   "status": "INACTIVE", // Status remains INACTIVE after update
#   "userId": "5f8f8f8f8f8f8f8f8f8f8f8f", // Example User ID
#   "location": {
#     "cityId": "city-id-123",
#     "point": {
#       "latitude": 40.7128,
#       "longitude": -74.0060
#     }
#   },
#   "mediaPaths": [
#     "path/to/media/image1.jpg",
#     "path/to/media/details/image2.png"
#   ],
#   "mainPhotoPath": "path/to/media/image1.jpg",
#   "stock": 10,
#   "lockedStock": 0,
#   "availableStock": 10,
#   "volatilityProtection": true,
#   "peggedCurrency": "USD",
#   "isFrozen": false, // New field, dynamically calculated
#   "createdAt": "2023-01-01T10:00:00Z",
#   "updatedAt": "2023-01-01T10:05:00Z"
# }

### Expected Response (Not Found - 404 Not Found):
# Content-Type: application/json
#
# {
#   "error": "Ad with ID {adId} not found for this user."
# }

### Expected Response (Bad Request - 400 Bad Request):
# Content-Type: application/json
#
# Conflict: sending fields that belong to the wrong pricing mode
# {
#   "success": false,
#   "status": "AD_FIXED_CRYPTO_CONFLICTING_PRICE",
#   "message": "Cannot set a reference price when using Fixed Crypto pricing. Use fixedPrices to set per-currency prices.",
#   "data": null
# }
# or
# {
#   "success": false,
#   "status": "AD_FIXED_CRYPTO_CONFLICTING_SETTLEMENT",
#   "message": "Cannot set settlement currencies explicitly when using Fixed Crypto pricing. Settlement currencies are derived from fixedPrices.",
#   "data": null
# }
# or
# {
#   "success": false,
#   "status": "AD_PEGGED_CONFLICTING_FIXED_PRICES",
#   "message": "Cannot set fixedPrices when using Pegged pricing. Use price, priceCurrency, and settlementCurrencies instead.",
#   "data": null
# }
# or
# Incomplete active ad update
# {
#   "success": false,
#   "status": "AD_ACTIVE_AD_INCOMPLETE_UPDATE",
#   "message": "This update would leave the active ad in an incomplete state. Ensure title, description, price (in a supported settlement currency), location, and stock (> 0) are all set, or deactivate the ad first to save incomplete changes.",
#   "data": null,
#   "fieldErrors": [
#     {"field": "stock", "message": "Stock must be greater than zero."}
#   ]
# }
# or
# DTO validation errors
# {
#   "success": false,
#   "status": "BAD_REQUEST",
#   "message": "The request is invalid.",
#   "data": null,
#   "fieldErrors": [
#     {"field": "title", "message": "Title cannot exceed 100 characters."},
#     {"field": "price", "message": "Price must be positive."}
#   ]
# }
# or
# {
#   "success": false,
#   "status": "AD_INVALID_AD_STATUS",
#   "message": "Invalid ad status for this operation.",
#   "data": null
# }

### Expected Response (Conflict - 409 Conflict):
# Content-Type: application/json
#
# {
#   "success": false,
#   "status": "AD_CONCURRENT_MODIFICATION",
#   "message": "The ad was modified by another operation. Please refresh and try again.",
#   "data": null
# }


### Activate an Ad
# Requires USER role authentication
# Changes the status of an INACTIVE ad to ACTIVE.
# Replace {adId} with the actual ID of the ad you want to activate.
# @name /sales/ads/{adId}/activate [POST]
POST {{host}}/api/sales/ads/{adId}/activate
Authorization: Bearer {{auth_token}}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "id": "{adId}", // The activated Ad ID
#   "title": "Updated Ad Title", // Or original title if not updated
#   "description": "This is a detailed description of the item.", // Or null/previous value
#   "price": 19.99, // Or null/previous value
#   "currency": "YEC", // Or null/previous value
#   "status": "ACTIVE", // Status is now ACTIVE
#   "userId": "5f8f8f8f8f8f8f8f8f8f8f8f", // Example User ID
#   "location": { // Or null/previous value
#     "cityId": "city-id-123",
#     "point": {
#       "latitude": 40.7128,
#       "longitude": -74.0060
#     }
#   },
#   "mediaPaths": [ // Or null/previous value
#     "path/to/media/image1.jpg",
#     "path/to/media/details/image2.png"
#   ],
#   "mainPhotoPath": "path/to/media/image1.jpg", // Or null/previous value
#   "stock": 10,
#   "lockedStock": 0,
#   "availableStock": 10,
#   "createdAt": "2023-01-01T10:00:00Z",
#   "updatedAt": "2023-01-01T10:10:00Z"
# }

### Expected Response (Not Found - 404 Not Found):
# Content-Type: application/json
#
# {
#   "error": "Ad with ID {adId} not found for this user."
# }

### Expected Response (Bad Request - 400 Bad Request):
# Content-Type: application/json
#
# {
#   "success": false,
#   "status": "AD_INCOMPLETE_AD_DATA",
#   "message": "Ad cannot be activated until title, description, price (in a supported settlement currency), location, and stock are set.",
#   "data": null,
#   "fieldErrors": [
#     {"field": "description", "message": "Description is required."},
#     {"field": "price", "message": "Price is required."},
#     {"field": "stock", "message": "Stock must be greater than zero."}
#   ]
# }
# or
# {
#   "success": false,
#   "status": "AD_INVALID_AD_STATUS",
#   "message": "Invalid ad status for this operation.",
#   "data": null
# }


### Deactivate an Ad
# Requires USER role authentication
# Changes the status of an ACTIVE ad to INACTIVE.
# Replace {adId} with the actual ID of the ad you want to deactivate.
# @name /sales/ads/{adId}/deactivate [POST]
POST {{host}}/api/sales/ads/{adId}/deactivate
Authorization: Bearer {{auth_token}}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "id": "{adId}", // The deactivated Ad ID
#   "status": "INACTIVE", // Status is now INACTIVE
#   "updatedAt": "2023-01-01T10:15:00Z"
# }

### Expected Response (Not Found - 404 Not Found):
# Content-Type: application/json
#
# {
#   "error": "Ad not found with ID: {adId}"
# }

### Expected Response (Bad Request - 400 Bad Request):
# Content-Type: application/json
#
# {
#   "error": "Ad can only be deactivated when in ACTIVE state."
# }

### Fetch My Ads
# Requires USER role authentication
# Fetches ads belonging to the authenticated user.
# @name /sales/ads/ [GET]
GET {{host}}/api/sales/ads/?p=0&t=Awesome&s=ACTIVE,INACTIVE
Authorization: Bearer {{auth_token}}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "content": [
#     {
#       "id": "60f8f9b3a9d9e8f8a8b8c8d8",
#       "title": "My Awesome New Ad Title",
#       "status": "ACTIVE",
#       "stock": 10,
#       "lockedStock": 2,
#       "availableStock": 8,
#       ...
#     }
#   ],
#   "totalPages": 1,
#   "totalElements": 1,
#   ...
# }


### Get Allowed Settlement Currencies
# Requires USER role authentication
# Retrieves the list of settlement currencies the authenticated user is allowed to list ads in.
# @name /sales/ads/allowed-currencies [GET]
GET {{host}}/api/sales/ads/allowed-currencies
Authorization: Bearer {{auth_token}}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# [
#   {
#     "code": "ARRR",
#     "name": "Pirate Chain"
#   },
#   {
#     "code": "YEC",
#     "name": "YCash"
#   }
# ]


### Fetch Single Ad for Seller
# Requires USER role authentication
# Fetches full details for a specific ad owned by the seller.
# @name /sales/ads/{adId} [GET]
GET {{host}}/api/sales/ads/{adId}
Authorization: Bearer {{auth_token}}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "id": "{adId}",
#   "title": "Updated Ad Title",
#   "status": "ACTIVE",
#   "categoryId": 5181,
#   "categoryPath": [
#     { "id": 1, "name": "Animals & Pet Supplies" },
#     { "id": 3, "name": "Pet Supplies" },
#     { "id": 5181, "name": "Bird Supplies" }
#   ],
#   "stock": 10,
#   "lockedStock": 2,
#   "availableStock": 8,
#   ...
# }
