### Register User
# Creates a new user account. The account will initially be unverified.
# Registration requires a unique username and email.
# @name register
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "username": "testuser",
  "password": "Password123!",
  "email": "test@example.com",
  "countryOfResidence": "US"
}

### Expected Response (Success - 201 Created):
# Content-Type: application/json
#
# {
#   "success": true,
#   "status": "SUCCESS",
#   "message": "Operation completed successfully."
# }


### Login User
# Authenticates a user and returns an access token and refresh token.
# The access token is short-lived (default 15 min). Use the refresh token to obtain new access tokens.
# @name login
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "username": "playground_seller",
  "password": "Password1",
  "deviceId": "web-browser-abc123"
}

> {%
    if (response.body.accessToken) {
        client.global.set("auth_token", response.body.accessToken);
        client.global.set("access_token", response.body.accessToken);
    }
    if (response.body.refreshToken) {
        client.global.set("refresh_token", response.body.refreshToken);
    }
%}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "success": true,
#   "status": "SUCCESS",
#   "message": "Operation completed successfully.",
#   "accessToken": "eyJ...",
#   "refreshToken": "dGhpcyBpcyBhIHJlZnJlc2ggdG9rZW4..."
# }


### Verify User
# Verifies the user's account using a code sent to their email.
# Requires a valid (but possibly unverified) session.
# @name verifyUser
POST {{host}}/api/auth/verifyUser
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "code": "123456",
  "deviceId": "web-browser-abc123"
}

> {%
    if (response.body.accessToken) {
        client.global.set("auth_token", response.body.accessToken);
        client.global.set("access_token", response.body.accessToken);
    }
    if (response.body.refreshToken) {
        client.global.set("refresh_token", response.body.refreshToken);
    }
%}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "success": true,
#   "status": "SUCCESS",
#   "message": "Operation completed successfully.",
#   "accessToken": "eyJ...",
#   "refreshToken": "dGhpcyBpcyBhIHJlZnJlc2ggdG9rZW4..."
# }


### Check Username Availability
# Checks if a username is already taken.
# @name checkUsername
POST {{host}}/api/auth/register/usernameAvailable
Content-Type: application/json

{
  "username": "testuser"
}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "available": false
# }


### Check Email Availability
# Checks if an email is already associated with an account.
# @name checkEmail
POST {{host}}/api/auth/register/emailAvailable
Content-Type: application/json

{
  "email": "test@example.com"
}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "available": false
# }


### Init Session
# Checks the current authentication status based on the Authorization header.
# @name initSession
GET {{host}}/api/auth/session/init
Authorization: Bearer {{auth_token}}

> {%
    if (response.body.accessToken) {
        client.global.set("auth_token", response.body.accessToken);
        client.global.set("access_token", response.body.accessToken);
    }
%}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "success": true,
#   "accessToken": "..."
# }


### Change Password
# Allows an authenticated user to change their password.
# @name changePassword
POST {{host}}/api/auth/changePassword
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "oldPassword": "OldPassword123!",
  "newPassword": "NewPassword456!"
}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "success": true,
#   "status": "SUCCESS",
#   "message": "Operation completed successfully."
# }


### Refresh Access Token
# Exchanges a valid refresh token for a new access token and a rotated refresh token.
# The old refresh token is invalidated after use (token rotation).
# If a previously-rotated token is reused, all sessions in that token family are revoked.
# This endpoint does not require an Authorization header.
# @name refreshToken
POST {{host}}/api/auth/token/refresh
Content-Type: application/json

{
  "refreshToken": "{{refresh_token}}",
  "deviceId": "web-browser-abc123"
}

> {%
    if (response.body.accessToken) {
        client.global.set("auth_token", response.body.accessToken);
        client.global.set("access_token", response.body.accessToken);
    }
    if (response.body.refreshToken) {
        client.global.set("refresh_token", response.body.refreshToken);
    }
%}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "success": true,
#   "status": "SUCCESS",
#   "message": "Operation completed successfully.",
#   "accessToken": "eyJ...",
#   "refreshToken": "bmV3IHJlZnJlc2ggdG9rZW4..."
# }

### Expected Response (Reuse Detected - 401 Unauthorized):
# Content-Type: application/json
#
# {
#   "success": false,
#   "status": "AUTH_REFRESH_TOKEN_REUSE_DETECTED",
#   "message": "A security issue was detected with your session. All sessions have been revoked. Please log in again."
# }


### Logout (Revoke Current Session)
# Logs out the current device by revoking the provided refresh token.
# Requires a valid access token in the Authorization header.
# @name logout
POST {{host}}/api/auth/logout
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "refreshToken": "{{refresh_token}}"
}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "success": true,
#   "status": "SUCCESS",
#   "message": "Operation completed successfully."
# }


### Revoke Specific Session
# Revokes a specific refresh token, ending that device session.
# Requires a valid access token.
# @name revokeSession
POST {{host}}/api/auth/sessions/revoke
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "refreshToken": "{{refresh_token}}"
}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "success": true,
#   "status": "SUCCESS",
#   "message": "Operation completed successfully."
# }


### Revoke All Sessions
# Revokes all refresh tokens for the authenticated user, logging out from all devices.
# Requires a valid access token.
# @name revokeAllSessions
POST {{host}}/api/auth/sessions/revoke-all
Content-Type: application/json
Authorization: Bearer {{auth_token}}

### Expected Response (Success - 200 OK):
# Content-Type: application/json
#
# {
#   "success": true,
#   "status": "SUCCESS",
#   "message": "Operation completed successfully."
# }
